# ─── Server ─────────────────────────────────────────────────────
# Port the API server listens on
PORT=3000

# Comma-separated list of allowed CORS origins (Netlify URL + local dev)
ALLOWED_ORIGINS=https://avurudhu.artslabcreatives.com,http://localhost:5173

# ─── Database ────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file
# The directory is created automatically on first run
DB_PATH=./data/game.db

# ─── JWT ─────────────────────────────────────────────────────────
# Secret key used to sign JWTs — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
